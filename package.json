{
  "name": "inkwell",
  "version": "1.0.0",
  "description": "InkWell - A Modern Blogging Platform",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push --schema=backend/prisma/schema.prisma"
    ,"postinstall": "npx prisma generate --schema=backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "bcrypt": "5.1.1",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dompurify": "3.1.4",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.2.0",
    "file-type": "19.0.0",
    "helmet": "7.1.0",
    "jsdom": "24.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "^1.4.5-lts.1",
    "resend": "3.2.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "nodemon": "3.1.2",
    "prisma": "5.14.0"
  }
}
